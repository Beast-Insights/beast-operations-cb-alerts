# Allow installs through transitive peer-dep conflicts that don't affect us.
# Specifically: tailwind-variants@3 expects tailwind-merge>=3 (peerOptional),
# but the rest of the app (Tremor components) is on tailwind-merge@2. Local
# `npm install` resolves this fine; Vercel's npm 10 enforces peer deps unless
# this flag is set.
legacy-peer-deps=true
