# Copy this file to `.env.local` for local development and fill in real values.
# On Vercel, set the same vars under Project Settings → Environment Variables
# (apply to Production, Preview, and Development).

# ---------------------------------------------------------------------------
# Database — required
# ---------------------------------------------------------------------------
# Either provide a single connection string:
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# ...or split into individual vars (used only when DATABASE_URL is unset):
# PGHOST=
# PGPORT=5432
# PGUSER=
# PGPASSWORD=
# PGDATABASE=

# ---------------------------------------------------------------------------
# SSL behavior — optional
# ---------------------------------------------------------------------------
# Default 'require' accepts the upstream cert without strict validation
# (necessary for the beastinsights DB on Vercel/CI). Set to 'strict' to
# enforce cert validation, 'disable' for plaintext (never against prod).
# PGSSL=require

# ---------------------------------------------------------------------------
# Pool tuning — optional, defaults shown
# ---------------------------------------------------------------------------
# PG_POOL_MAX=5          # max concurrent connections per server instance
# PG_IDLE_MS=5000        # release idle connections after N ms
# PG_CONNECT_MS=15000    # wait N ms for a free slot before failing
# PG_QUERY_MS=30000      # cancel any single query after N ms
